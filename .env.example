# ============================================================================
# OpenLab Website — environment variables example
# Copy to .env.local for dev (never commit .env.local).
# Production secrets are managed via SealedSecrets (cf. §14.8 CLAUDE.md).
# ============================================================================

# --- Next.js ---
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Database (Postgres 17) ---
DATABASE_URL=postgresql://openlab:devpass@localhost:5432/openlab

# --- Redis (sessions, rate limit) ---
REDIS_URL=redis://localhost:6379

# --- MinIO (S3-compatible storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=openlab-media
MINIO_USE_SSL=false

# --- Meilisearch ---
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=devmasterkey

# --- Payload CMS ---
# Générer un secret de 32 bytes : `openssl rand -hex 32`
PAYLOAD_SECRET=replace-with-32-byte-random-hex
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# --- Seed initial du super-admin (utilisé par pnpm cms:seed) ---
# Idempotent : si l'utilisateur existe déjà, le script ne touche à rien.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=

# --- Auth (Better-Auth) ---
BETTER_AUTH_SECRET=replace-with-32-byte-random-hex
BETTER_AUTH_URL=http://localhost:3000

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=

# --- Email transactionnel (Zoho ZeptoMail) ---
# Token « Send Mail » généré dans la console ZeptoMail (Mail Agents).
# Absent en dev/CI → l'envoi est silencieusement sauté (fail-soft).
ZEPTOMAIL_TOKEN=
# Endpoint API selon la zone du compte Zoho (EU par défaut, sinon .com / .in).
ZEPTOMAIL_API_URL=https://api.zeptomail.eu/v1.1/email
# Expéditeur (doit être un domaine vérifié dans ZeptoMail).
EMAIL_FROM=noreply@openlabconsulting.com
EMAIL_FROM_NAME=OpenLab Consulting
# Boîte qui reçoit les notifications de leads.
EMAIL_TEAM=waopron@openlabconsulting.com

# --- Analytics (Plausible self-hosted) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=openlabconsulting.com
NEXT_PUBLIC_PLAUSIBLE_API_HOST=

# --- Anti-bot (Cloudflare Turnstile) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- 2FA admin obligatoire (OWASP A07) ---
# `true` => le middleware exige une session TOTP valide pour accéder à /admin
# (redirige vers /admin-2fa sinon). À activer UNIQUEMENT après avoir configuré
# son TOTP et testé le flux, sinon risque de lockout.
# Break-glass : repasser à false, ou `UPDATE users SET totp_enabled=false`.
ENFORCE_ADMIN_2FA=false
